{
  "expo": {
    "name": "Гэвабал",
    "slug": "given-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "given-mobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFBF0"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "mn.gevabal.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFBF0"
      },
      "package": "mn.gevabal.mobile",
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-router",
        {
          "root": "./app"
        }
      ],
      "expo-secure-store",
      "expo-web-browser",
      [
        "@config-plugins/react-native-webrtc",
        {
          "cameraPermission": "Гэвабал аппд камер ашиглах зөвшөөрөл өгнө үү.",
          "microphonePermission": "Гэвабал аппд микрофон ашиглах зөвшөөрөл өгнө үү."
        }
      ]
    ]
  }
}